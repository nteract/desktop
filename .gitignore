# Cargo.lock checked in for binaries
# Cargo.lock

# MCPB build artifacts
*.mcpb

# iPython
.ipynb_checkpoints
Untitled*.ipynb

# Dev mode notebooks directory (repo root only)
/notebooks/

# Local sqlite db files
*.db
*.db-wal
*.db-shm

# Local environment
.env

