      "id": "132467cc-ad5d-4cbd-8972-16a875ebd15d",
      "cell_type": "code",
      "source": [
        "import sys\n",
        "import time\n",
        "\n",
        "blink = lambda: time.sleep(8 * 60 / 1000) and sys.stdout.flush()\n",
        "\n",
        "print(\"top\", end=\"\")\n",
        "blink()\n",
        "\n",
        "print(\"\\rT\")\n",
        "blink()\n",
        "\n",
        "display(\"middle\")\n",
        "blink()\n",
        "\n",
        "print(\"bottom\", end=\"\")\n",
        "sys.stdout.flush()\n",
        "blink()\n",
        "\n",
        "print(\"\\rB\")"
      ],
      "metadata": {},
      "outputs": [
        {
          "output_type": "stream",
