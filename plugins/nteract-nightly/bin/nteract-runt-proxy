#!/usr/bin/env bash
set -euo pipefail

channel="${NTERACT_CHANNEL:-stable}"
binary_name="runt-proxy"

if [[ "$channel" == "nightly" ]]; then
  app_names=("nteract Nightly" "nteract-nightly" "nteract (Nightly)")
else
  app_names=("nteract")
fi

candidate_paths=()

case "$(uname -s)" in
  Darwin)
    for app_name in "${app_names[@]}"; do
      candidate_paths+=("/Applications/${app_name}.app/Contents/MacOS/${binary_name}")
      candidate_paths+=("${HOME}/Applications/${app_name}.app/Contents/MacOS/${binary_name}")
    done
    ;;
  Linux)
    # Dev-installed nightly (cargo xtask install-nightly) lands binaries with
    # channel-suffixed names. Prefer those when channel != stable.
    if [[ "$channel" != "stable" ]]; then
      candidate_paths+=("/usr/local/bin/runt-proxy-${channel}")
      candidate_paths+=("${HOME}/.local/share/runt-${channel}/bin/runt-proxy-${channel}")
    fi
    candidate_paths+=("${HOME}/.local/bin/${binary_name}")
    for app_name in "${app_names[@]}"; do
      app_slug="$(printf '%s' "$app_name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
      candidate_paths+=("/usr/share/${app_slug}/${binary_name}")
      candidate_paths+=("/opt/${app_slug}/${binary_name}")
    done
    ;;
  MINGW*|MSYS*|CYGWIN*)
    local_app_data="${LOCALAPPDATA:-${HOME}/AppData/Local}"
    binary_name="runt-proxy.exe"
    for app_name in "${app_names[@]}"; do
      candidate_paths+=("${local_app_data}/${app_name}/${binary_name}")
      candidate_paths+=("${local_app_data}/Programs/${app_name}/${binary_name}")
    done
    ;;
esac

for candidate in "${candidate_paths[@]}"; do
  if [[ -f "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

cat >&2 <<EOF
nteract Codex plugin error: could not find the app-bundled ${binary_name}.
Install the nteract desktop app and try again.

Expected locations for channel '${channel}':
$(printf '  %s\n' "${candidate_paths[@]}")
EOF
exit 1
