   "source": [
    "import sys\n",
    "import time\n",
    "\n",
    "(stdout, stderr) = sys.stdout, sys.stderr\n",
    "\n",
    "\n",
    "def blink():\n",
    "    time.sleep(60 / 1000)\n",
    "    stdout.flush()\n",
    "    stderr.flush()\n",
    "\n",
    "\n",
    "stdout.write(\"test\")\n",
    "blink()\n",
    "\n",
    "stdout.write(\" test\")\n",
    "blink()\n",
    "\n",
    "stdout.write(\"\\rB\")\n",
    "blink()"
   ],
