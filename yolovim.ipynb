n\u001b[0m\u001b[32m\\n~\\n~\\n~\\n~\\n\\u001b[0mType  :qa  and press <Enter> to exit Vim                      0,0-1         All\\u001b[0m\"\n\u001b[0m        \u001b[1m},\n\u001b[0m        \u001b[1m{\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"output_type\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"error\"\u001b[0m\u001b[1m,\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"ename\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"KeyboardInterrupt\"\u001b[0m\u001b[1m,\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"evalue\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"\"\u001b[0m\u001b[1m,\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"traceback\"\u001b[0m\u001b[1m:\u001b[0m \u001b[1m[\n\u001b[0m            \u001b[0m\u001b[32m\"\\u001b[31m---------------------------------------------------------------------------\\u001b[39m\"\u001b[0m\u001b[1m,\n\u001b[0m            \u001b[0m\u001b[32m\"\\u001b[31mKeyboardInterrupt\\u001b[39m                         Traceback (most recent call last)\"\u001b[0m\u001b[1m,\n\u001b[0m            \u001b[0m\u001b[32m\"\\u001b[36mFile \\u001b[39m\\u001b[32m~/notebooks/.venv/lib/python3.12/site-packages/IPython/utils/_process_po\n\u001b[0m\u001b[32msix.py:130\\u001b[39m, in \\u001b[36mProcessHandler.system\\u001b[39m\\u001b[34m(self, cmd)\\u001b[39m\\n\\u001b[32m    127\\u00\n\u001b[0m\u001b[32m1b[39m \\u001b[38;5;28;01mwhile\\u001b[39;00m \\u001b[38;5;28;01mTrue\\u001b[39;00m:\\n\\u001b[32m    128\\u001b[39m     \\u001b\n\u001b[0m\u001b[32m[38;5;66;03m# res is the index of the pattern that caused the match, so we\\u001b[39;00m\\n\\u001b[32m    129\\u001b[39m\n\u001b[0m\u001b[32m \\u001b[38;5;66;03m# know whether we've finished (if we matched EOF) or not\\u001b[39;00m\\n\\u001b[32m--> \\u001b[39m\\u001b\n\u001b[0m\u001b[32m[32m130\\u001b[39m     res_idx = \\u001b[43mchild\\u001b[49m\\u001b[43m.\\u001b[49m\\u001b[43mexpect_list\\u001b[49m\\u001b[43m(\n\u001b[0m\u001b[32m\\u001b[49m\\u001b[43mpatterns\\u001b[49m\\u001b[4