b[0m\u001b[32m\"import time\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"print(\\\"hey\\\", end=\\\"\\\")\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"time.sleep(1)\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"import sys\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"sys.stdout.flush()\\n\"\u001b[0m\u001b[1m,\n\u001b[0m        \u001b[0m\u001b[32m\"print(\\\"\\\\rwhat\\\")\"\n\u001b[0m      \u001b[1m],\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"metadata\"\u001b[0m\u001b[1m:\u001b[0m \u001b[1m{},\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"outputs\"\u001b[0m\u001b[1m:\u001b[0m \u001b[1m[\n\u001b[0m        \u001b[1m{\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"output_type\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"stream\"\u001b[0m\u001b[1m,\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"name\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"stdout\"\u001b[0m\u001b[1m,\n\u001b[0m          \u001b[0m\u001b[1m\u001b[34m\"text\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"what\\u001b[0m\"\n\u001b[0m        \u001b[1m}\n\u001b[0m      \u001b[1m],\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"execution_count\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[90mnull\n\u001b[0m    \u001b[1m},\n\u001b[0m    \u001b[1m{\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"id\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"1ace5339-24e5-4b0c-b45a-63215c6eadc5\"\u001b[0m\u001b[1m,\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"cell_type\"\u001b[0m\u001b[1m:\u001b[0m \u001b[0m\u001b[32m\"code\"\u001b[0m\u001b[1m,\n\u001b[0m      \u001b[0m\u001b[1m\u001b[34m\"source\"\u001b[0m\u001b[1m:\u001b[0m \u001b[1m[\n\u001b[0m        \u001b[0m\u001b[32m\"!vim\"\n\u001b[0m      \u001b[1m],\n\u001b[0m      \u001b[0m\u001