[
  {
    "label": "Dev Daemon",
    "command": "cargo xtask dev-daemon",
    "env": {
      "RUST_LOG": "debug",
      "RUNTIMED_DEV": "1",
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
  },
  {
    "label": "Dev App",
    "command": "export RUNTIMED_VITE_PORT=$((5100 + $(echo -n \"$ZED_WORKTREE_ROOT\" | cksum | cut -d' ' -f1) % 4900)); echo \"Vite port: $RUNTIMED_VITE_PORT\"; cargo xtask notebook",
    "env": {
      "RUNTIMED_DEV": "1",
      "RUST_LOG": "debug",
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
  },
  {
    "label": "Setup",
    "command": "pnpm install && cargo xtask build",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Daemon Status",
    "command": "./target/debug/runt daemon status",
    "env": {
      "RUNTIMED_DEV": "1",
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Daemon Logs",
    "command": "./target/debug/runt daemon logs -f",
    "env": {
      "RUNTIMED_DEV": "1",
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
  },
  {
    "label": "Test (notebook crate)",
    "command": "cargo test -p notebook",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "Format",
    "command": "cargo fmt && npx @biomejs/biome check --fix apps/notebook/src/ e2e/",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "E2E Build",
    "command": "./e2e/dev.sh build",
    "env": {
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "E2E Fixture Tests",
    "command": "./e2e/dev.sh test-fixtures",
    "env": {
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
  },
  {
    "label": "E2E All Tests",
    "command": "./e2e/dev.sh cycle",
    "env": {
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
  },
  {
    "label": "Dev MCP (print config)",
    "command": "cargo xtask dev-mcp --print-config",
    "env": {
      "RUNTIMED_DEV": "1",
      "RUNTIMED_WORKSPACE_PATH": "$ZED_WORKTREE_ROOT",
    },
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
]
