  {
    "name": "list_active_notebooks",
    "description": "List all notebook sessions running in the daemon. Returns notebooks opened by any user or agent. Use open_notebook(notebook) to connect to one as your active session.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
