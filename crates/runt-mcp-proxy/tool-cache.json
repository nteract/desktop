      "title": "EmptyParams",
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": true,
      "openWorldHint": false
    },
    "_meta": {
      "anthropic/alwaysLoad": true
    }
  },
  {
    "name": "open_notebook",
    "description": "Open a notebook by file path or connect to a running session by ID. Accepts a file path (e.g. '~/analysis.ipynb') or a notebook_id from list_active_notebooks. Makes it your active session.",
